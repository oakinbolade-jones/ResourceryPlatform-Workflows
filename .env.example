# Copy this file to .env and adjust values for your environment.
# Docker Compose automatically reads .env from the working directory.

SQLSERVER_HOST=host.docker.internal
SQLSERVER_PORT=1433
SQLSERVER_USER=sa
SQLSERVER_PASSWORD=P@ssw0rd123*

# Shared service connection settings
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PORT_INTERNAL=6379
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_PORT_INTERNAL=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# Internal service URLs
IDENTITY_SERVICE_INTERNAL_URL=http://identity-service:8080/
IDENTITY_SERVER_INTERNAL_URL=http://identity-server

# Published ports
IDENTITY_SERVICE_PORT=7004
ADMINISTRATION_SERVICE_PORT=7001
SAAS_SERVICE_PORT=7002
WORKFLOW_SERVICE_PORT=7003

# Stack-specific published ports
IDENTITY_STACK_SERVICE_PORT=7004
IDENTITY_STACK_REDIS_PORT=6379
IDENTITY_STACK_RABBITMQ_PORT=5672
IDENTITY_STACK_RABBITMQ_MGMT_PORT=15672
ADMIN_STACK_IDENTITY_SERVER_PORT=51600
ADMIN_STACK_SERVICE_PORT=51601
SAAS_STACK_IDENTITY_SERVER_PORT=51600
SAAS_STACK_SERVICE_PORT=51601
WORKFLOW_STACK_IDENTITY_SERVER_PORT=51600
WORKFLOW_STACK_SERVICE_PORT=51601

# UI/CORS
APP_CORS_ORIGINS=http://localhost:4200,http://localhost:7001,http://localhost:7002,http://localhost:7003,http://localhost:7004
