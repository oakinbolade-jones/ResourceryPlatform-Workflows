
@using Microsoft.AspNetCore.Mvc.Localization
@using Volo.Abp.Account.Localization
@using ResourceryPlatformWorkflow.Workflow.Localization
@using Volo.Abp.Account.Settings
@using Volo.Abp.Identity
@using Volo.Abp.Settings
@model ResourceryPlatformWorkflow.AuthServer.Pages.Account.ManageModel
@inject IHtmlLocalizer<AccountResource> L
@inject IHtmlLocalizer<ResourceryPlatformWorkflow.Workflow.Localization.WorkflowResource> LW
@inject Volo.Abp.Settings.ISettingProvider SettingProvider

<!-- FORMATTED TO MATCH LOGIN/REGISTER PAGE LAYOUT -->
<div class="lpx-content-container">
    <div class="lpx-content">
        <div class="container-fluid my-5">
            <div class="row justify-content-center my-5">
                <div class="col-12 col-md-12 col-lg-12 col-xl-12 d-flex justify-content-start w-50">
                    <img src="/images/logo/ecw-smartserve-logo.png" alt="DCP Smart Serve Platform" style="max-width: 220px;" />
                </div>
            </div>
            <div class="row justify-content-center">
                <div class="col-12 col-md-12 col-lg-12 col-xl-12 d-flex justify-content-start w-50">
                    <div class="row g-0 shadow-lg border border-success rounded-1 overflow-hidden w-75 justify-content-center">
                        <div class="col-12 col-md-5 bg-white text-dark d-flex flex-column justify-content-stretch p-5 left-side">
                            <h2 class="h3 mb-3 fs-2 fw-bold">@L["ManageAccount"]</h2>
                            <p class="fw-normal fs-6 text-body-secondary">@L["Manage your account settings and security options."]</p>
                            <p class="mt-auto mb-0 small opacity-75">
                                <hr />
                                @L["ECOWASCopyright"] <br />
                                @L["ECOWAS"]
                            </p>
                        </div>
                        <div class="col-12 col-md-7 bg-white p-5 w-50">
                            <!-- Manage form section (edit freely) -->
                            <form method="post" class="mt-4">
                                <abp-validation-summary />
                                <!-- Add your account management fields here -->
                                <div class="mb-3">
                                    <label asp-for="Input.Email" class="form-label"></label>
                                    <input asp-for="Input.Email" class="form-control border border-success rounded-0 p-2" autocomplete="off" placeholder="Email address" />
                                    <span asp-validation-for="Input.Email" class="text-danger"></span>
                                </div>
                                <div class="mb-3">
                                    <label asp-for="Input.PhoneNumber" class="form-label"></label>
                                    <input asp-for="Input.PhoneNumber" class="form-control border border-success rounded-0 p-2" autocomplete="off" placeholder="Phone number" />
                                    <span asp-validation-for="Input.PhoneNumber" class="text-danger"></span>
                                </div>
                                <div class="d-grid gap-2">
                                    <abp-button button-type="Primary" type="submit" class="btn-lg mt-4 btn btn-success rounded-0">@L["SaveChanges"]</abp-button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
